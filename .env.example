# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here-must-be-random
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Email Configuration (SMTP)
DJANGO_EMAIL_HOST=smtp.gmail.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_USE_TLS=True
DJANGO_EMAIL_HOST_USER=your-email@gmail.com
DJANGO_EMAIL_HOST_PASSWORD=your-app-password

# Database (optional - for PostgreSQL if you want to use it instead of SQLite)
# DATABASE_URL=postgres://user:password@localhost:5432/dbname
